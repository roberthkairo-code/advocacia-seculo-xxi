# ============================================================
# Advocacia do Século XXI - Variáveis de Ambiente
# Copie este arquivo para .env e preencha com suas credenciais
# NUNCA commite o arquivo .env no repositório!
# ============================================================

# --- Claude / Anthropic ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-opus-4-5

# --- Microsoft Graph API (Calendar + To Do) ---
MICROSOFT_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MICROSOFT_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MICROSOFT_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MICROSOFT_REDIRECT_URI=http://localhost:8000/auth/callback

# --- WhatsApp (Evolution API) ---
WHATSAPP_API_URL=http://localhost:8080
WHATSAPP_INSTANCE=advocacia
WHATSAPP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER=5511999999999

# --- Banco de Dados ---
DATABASE_URL=sqlite:///./advocacia.db
# Para PostgreSQL: postgresql://user:password@localhost/advocacia

# --- Configurações da Aplicação ---
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
SECRET_KEY=sua-chave-secreta-muito-longa-e-aleatoria

# --- OCR (Google Vision - opcional) ---
GOOGLE_APPLICATION_CREDENTIALS=/caminho/para/credentials.json

# --- Notificações ---
# Intervalo de verificação de prazos (em minutos)
DEADLINE_CHECK_INTERVAL=60
# Quantos dias antes do prazo enviar alerta
DEADLINE_ALERT_DAYS=3,1
